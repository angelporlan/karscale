---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'en' } },
  ];
}

const { lang } = Astro.params;

const posts = await getCollection('blog', ({ data }) => {
  return data.lang === lang;
});

posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const esDateOptions: Intl.DateTimeFormatOptions = { year: 'numeric', month: 'long', day: 'numeric' };
---

<Layout title={`Inicio | ${lang?.toUpperCase()}`}>
  <header class="mb-20 mt-10">
    <h1 class="text-5xl md:text-6xl font-extrabold tracking-tight mb-6 text-transparent bg-clip-text bg-gradient-to-br from-white to-gray-500">
      Últimos Registros
    </h1>
    <p class="text-xl text-gray-400 font-light">
      Datos recuperados sobre civilizaciones futuras, estructuras megadimensionales y exploración profunda.
    </p>
  </header>

  <div class="grid gap-8 relative">
    <!-- Línea decorativa del timeline -->
    <div class="absolute left-6 top-0 bottom-0 w-px bg-white/5 md:block hidden"></div>
    
    {posts.map(post => {
      // Extraemos el slug correcto sin el prefijo del idioma de la carpeta
      const slugParts = post.id.split('/');
      const isNested = slugParts.length > 1; // e.g. "es/my-post"
      const urlSlug = isNested ? slugParts.slice(1).join('/') : post.id;

      return (
        <article class="relative p-6 md:p-8 rounded-3xl border border-white/5 bg-white/[0.02] hover:bg-white/[0.04] transition-all duration-300 group ml-0 md:ml-12 hover:border-white/10 hover:shadow-[0_0_30px_rgba(0,0,0,0.5)]">
          <!-- Punto en el timeline -->
          <div class="absolute -left-[53px] top-1/2 -translate-y-1/2 w-3 h-3 rounded-full bg-neonPurple shadow-[0_0_10px_#b026ff] md:block hidden group-hover:scale-150 transition-transform"></div>

          <div class="flex items-center gap-4 mb-4">
            <span class="px-3 py-1 text-xs font-mono font-medium tracking-wide rounded-full border border-electricCyan/30 text-electricCyan bg-electricCyan/10 backdrop-blur-sm">
              {post.data.category}
            </span>
            <time class="text-sm text-gray-500 font-mono">
              {post.data.pubDate.toLocaleDateString(lang === 'es' ? 'es-ES' : 'en-US', esDateOptions)}
            </time>
          </div>
          <a href={`/${lang}/blog/${urlSlug}`} class="block outline-none">
            <h2 class="text-3xl font-bold mb-3 text-gray-100 group-hover:text-transparent group-hover:bg-clip-text group-hover:bg-gradient-to-r group-hover:from-white group-hover:to-gray-400 transition-all duration-300">
              {post.data.title}
            </h2>
          </a>
          <div class="flex flex-wrap gap-2 mt-4">
            {post.data.tags.map(tag => (
              <span class="text-xs font-mono text-gray-600 bg-black/50 px-2 py-1 rounded">#{tag}</span>
            ))}
          </div>
        </article>
      );
    })}
  </div>
</Layout>
