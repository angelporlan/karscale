---
import '../styles/global.css';

export interface Props {
  title: string;
  lang?: string;
}

const { title, lang = "es" } = Astro.props;
const currentLang = lang === "en" ? "en" : "es";
const alternateLang = currentLang === "es" ? "en" : "es";
const currentPath = Astro.url.pathname;
const alternatePath = currentPath.replace(/^\/(es|en)(?=\/|$)/, `/${alternateLang}`);
const ui = {
  es: {
    logbook: "Logbook",
    kardashov: "Kardashov",
    silence: "Silencio",
    cosmos: "Cosmos",
    searchPlaceholder: "Buscar en la escala...",
    privacy: "Privacidad",
    terms: "Términos",
    footerTagline: "© 2026 KARSCALE // TERMINAL DE INVESTIGACIÓN KARDASHEV TIPO II",
  },
  en: {
    logbook: "Logbook",
    kardashov: "Kardashov",
    silence: "Silence",
    cosmos: "Cosmos",
    searchPlaceholder: "Search the scale...",
    privacy: "Privacy",
    terms: "Terms",
    footerTagline: "© 2026 KARSCALE // TYPE II KARDASHEV RESEARCH TERMINAL",
  },
}[currentLang];
---

<!DOCTYPE html>
<html lang={currentLang} class="bg-deepSpace text-gray-200 dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="generator" content={Astro.generator} />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&family=Space+Grotesk:wght@400;700&display=swap" rel="stylesheet">
  <title>{title}</title>
</head>
<body data-lang={currentLang} class="min-h-screen font-sans antialiased relative selection:bg-neonPurple/30">
  <nav class="border-b border-white/5 bg-[#050505]/95 backdrop-blur-xl sticky top-0 z-50">
    <div class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <div class="flex items-center gap-10">
          <a href={`/${currentLang}`} class="text-xl font-bold font-heading tracking-tight text-white flex items-center">
            Kar<span class="text-secondary">scale</span>
          </a>
          <div class="hidden md:flex space-x-8 h-16">
             <a href={`/${currentLang}`} class="text-[10px] font-heading font-bold text-gray-300 uppercase tracking-[0.15em] border-b-2 border-primary py-5 inline-flex items-center h-full pt-6">{ui.logbook}</a>
             <a href={`/${currentLang}/kardashov`} class="text-[10px] font-heading font-bold text-gray-500 hover:text-gray-300 uppercase tracking-[0.15em] py-5 inline-flex items-center h-full pt-6 transition-colors border-b-2 border-transparent hover:border-white/10">{ui.kardashov}</a>
             <a href={`/${currentLang}/silencio`} class="text-[10px] font-heading font-bold text-gray-500 hover:text-gray-300 uppercase tracking-[0.15em] py-5 inline-flex items-center h-full pt-6 transition-colors border-b-2 border-transparent hover:border-white/10">{ui.silence}</a>
             <a href={`/${currentLang}/cosmos`} class="text-[10px] font-heading font-bold text-gray-500 hover:text-gray-300 uppercase tracking-[0.15em] py-5 inline-flex items-center h-full pt-6 transition-colors border-b-2 border-transparent hover:border-white/10">{ui.cosmos}</a>
          </div>
        </div>
        <div class="flex items-center gap-4 h-16">
          <div class="relative hidden sm:block">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
            </div>
            <input type="text" placeholder={ui.searchPlaceholder} class="bg-[#111] border border-white/5 rounded pl-10 pr-4 py-2.5 text-[11px] text-gray-300 font-body focus:outline-none focus:border-white/10 w-64 lg:w-80 transition-colors placeholder-gray-600">
          </div>
          <a href={alternatePath} class="flex items-center justify-center text-gray-500 hover:text-gray-300 transition-colors cursor-pointer pl-6 border-l border-white/5 h-full">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            <span class="text-[10px] font-heading font-bold tracking-[0.1em]">{currentLang.toUpperCase()}/{alternateLang.toUpperCase()}</span>
          </a>
        </div>
      </div>
    </div>
  </nav>

  <main class="relative z-10 w-full max-w-[1280px] mx-auto py-12 px-4 sm:px-6 lg:px-8">
    <slot />
  </main>

  <footer class="border-t border-white/5 py-10 mt-auto bg-[#050505] relative z-10">
    <div class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-8 flex flex-col xl:flex-row items-center justify-between gap-8 xl:gap-0">
      <div class="flex flex-col md:flex-row items-center gap-4 text-center md:text-left">
        <a href={`/${currentLang}`} class="text-xl font-bold font-heading tracking-tight text-white flex items-center">
            Kar<span class="text-secondary">scale</span>
        </a>
        <span class="text-gray-600 text-[9px] font-heading tracking-[0.2em] font-bold md:ml-4">
          © 2026 KARSCALE // KARDASHEV TYPE II RESEARCH TERMINAL
        </span>
      </div>

      <div class="flex flex-wrap items-center justify-center gap-6 xl:gap-8 text-[10px] font-heading font-bold text-gray-500 uppercase tracking-widest">
        <a href="#" class="hover:text-white transition-colors">{ui.privacy}</a>
        <a href="#" class="hover:text-white transition-colors">{ui.terms}</a>
        <a href={`/${currentLang}`} class="hover:text-white transition-colors">{ui.logbook}</a>
        <a href={`/${currentLang}/kardashov`} class="hover:text-white transition-colors">{ui.kardashov}</a>
        <a href={`/${currentLang}/silencio`} class="hover:text-white transition-colors">{ui.silence}</a>
        <a href={`/${currentLang}/cosmos`} class="hover:text-white transition-colors">{ui.cosmos}</a>
      </div>

      <div class="flex items-center gap-5 text-gray-500">
        <button class="hover:text-white transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 5c7.18 0 13 5.82 13 13M6 11a7 7 0 017 7m-6 0v.01M6 20h.01"></path></svg>
        </button>
        <button class="hover:text-white transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"></path></svg>
        </button>
      </div>
    </div>
  </footer>
</body>
</html>
